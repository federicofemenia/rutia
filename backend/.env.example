GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
PORT=3000
# Generar con: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# DATABASE_PROVIDER es obligatorio: "sqlite" (archivo local o :memory:) o "turso" (remoto).
DATABASE_PROVIDER=sqlite

# Solo se usa cuando DATABASE_PROVIDER=sqlite. Si se omite, el default es ./data/rutia.sqlite.
DATABASE_PATH=./data/rutia.sqlite

# Solo se usan cuando DATABASE_PROVIDER=turso. Obtenerlas con `turso db show <db> --url` y
# `turso db tokens create <db>`. rama development -> rutia-development, rama main -> rutia-production.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
